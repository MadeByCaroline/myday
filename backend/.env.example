DATABASE_URL="file:./dev.db"
JWT_SECRET="change-me-in-production"
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://127.0.0.1:3000/auth/google/callback"
MICROSOFT_CLIENT_ID="your-microsoft-client-id"
MICROSOFT_CLIENT_SECRET="your-microsoft-client-secret"
MICROSOFT_CALLBACK_URL="http://127.0.0.1:3000/auth/microsoft/callback"
META_APP_ID="your-meta-app-id"
META_APP_SECRET="your-meta-app-secret"
META_GRAPH_API_VERSION="v22.0"
TIKTOK_CLIENT_KEY="your-tiktok-client-key"
TIKTOK_CLIENT_SECRET="your-tiktok-client-secret"
REDIS_URL="redis://127.0.0.1:6379/0"
GEMINI_API_KEY="your-gemini-api-key"
FRONTEND_URL="http://127.0.0.1:5173"
PORT=3000

# Strict timeout (ms) applied to outgoing third-party integration requests
# (Google, Microsoft, AI). Prevents slow dependencies from blocking the server.
INTEGRATION_HTTP_TIMEOUT_MS=10000

STRIPE_SECRET_KEY=sk_test_...
STRIPE_MONTHLY_PRICE_ID=price_...
STRIPE_ANNUAL_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

NOTION_CLIENT_ID="your-notion-client-id"
NOTION_CLIENT_SECRET="your-notion-client-secret"

USE_LOCAL_AI=true
