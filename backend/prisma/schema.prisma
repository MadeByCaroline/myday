generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                    String       @id @default(cuid())
  email                 String       @unique
  name                  String?
  picture               String?
  role                  Role         @default(USER)
  isPremium             Boolean      @default(false)
  theme                 String       @default("light")
  dailySummary          String?
  aiSummaryInstructions String?
  excludedSenders       String       @default("[]")
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  oauthTokens           OAuthToken[]
  emailAccounts         EmailAccount[]
  socialAccounts        SocialAccount[]
  tasks                 Task[]
  timeEntries           TimeEntry[]
  workspaces            Workspace[]
}

enum Role {
  USER
  ADMIN
}

enum EmailProvider {
  GOOGLE
  MICROSOFT
  IMAP
}

enum SocialProvider {
  INSTAGRAM
  FACEBOOK
  TIKTOK
}

model OAuthToken {
  id           String   @id @default(cuid())
  userId       String
  workspaceId  String?
  provider     String
  email        String   @default("")
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  scope        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace    Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@unique([userId, provider, email])
  @@unique([provider, email])
  @@index([userId, workspaceId])
}

model EmailAccount {
  id           String        @id @default(cuid())
  userId       String
  provider     EmailProvider
  emailAddress String
  label        String
  accessToken  String?
  refreshToken String?
  expiresAt    DateTime?
  imapConfig   Json?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, provider])
  @@unique([userId, provider, emailAddress, label])
}

model SocialAccount {
  id                    String                 @id @default(cuid())
  userId                String
  provider              SocialProvider
  externalAccountId     String
  accessToken           String
  refreshToken          String?
  tokenExpiry           DateTime?
  tokenExpiringNotifiedAt DateTime?
  lastTotalViews        Int                    @default(0)
  lastFollowerCount     Int                    @default(0)
  lastEngagementRate    Float                  @default(0)
  lastSyncedAt          DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  metricSnapshots       SocialMetricSnapshot[]

  @@index([userId, provider])
  @@unique([userId, provider, externalAccountId])
}

model SocialMetricSnapshot {
  id             String        @id @default(cuid())
  socialAccountId String
  totalViews     Int
  followerCount  Int
  engagementRate Float
  recordedAt     DateTime      @default(now())
  socialAccount  SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)

  @@index([socialAccountId, recordedAt])
}

model Task {
  id          String      @id @default(cuid())
  userId      String
  workspaceId String?
  title       String
  description String?
  status      String      @default("TODO")
  source      String      @default("MANUAL")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace?  @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  timeEntries TimeEntry[]

  @@index([userId, workspaceId])
}

model Workspace {
  id         String       @id @default(cuid())
  name       String
  color      String
  icon       String
  userId     String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks      Task[]
  oauthTokens OAuthToken[]

  @@index([userId])
}

model TimeEntry {
  id        String   @id @default(cuid())
  startTime DateTime
  endTime   DateTime?
  duration  Int?
  taskId    String
  userId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, endTime])
  @@index([taskId])
}
